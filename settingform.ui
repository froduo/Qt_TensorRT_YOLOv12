  <property name="styleSheet">
   <string notr="true">
    QDialog {
        background-color: #0a0d14;
        color: #eef4ff;
    }
    QTabWidget::pane {
        background-color: #0f1828;
        border: 1px solid #364967;
        border-radius: 6px;
        padding: 8px;
    }
    QTabBar::tab {
        background-color: #151d2e;
        color: #8ab4f8;
        border: 1px solid #364967;
        border-bottom: none;
        border-top-left-radius: 6px;
        border-top-right-radius: 6px;
        padding: 8px 18px;
        margin-right: 2px;
        font-weight: 600;
        font-size: 12px;
    }
    QTabBar::tab:selected {
        background-color: #0f1828;
        color: #ffffff;
        border-bottom: 1px solid #0f1828;
    }
    QTabBar::tab:hover:!selected {
        background-color: #1a2540;
    }
    QGroupBox {
        color: #f2f6ff;
        border: 1px solid #364967;
        border-radius: 8px;
        margin-top: 14px;
        padding-top: 8px;
        font-weight: bold;
    }
    QGroupBox::title { left: 12px; padding: 0 6px; top: -2px; }
    QLabel {
        color: #eaf2ff;
    }
    QLineEdit, QDoubleSpinBox, QSpinBox, QComboBox {
        background-color: #111b2e;
        border: 1px solid #465e83;
        border-radius: 6px;
        color: #f4f8ff;
        selection-background-color: #2f62bb;
        selection-color: #ffffff;
        padding: 6px;
        min-height: 25px;
    }
    QLineEdit:focus, QSpinBox:focus, QDoubleSpinBox:focus {
        border: 1px solid #4f7fd4;
    }
    QComboBox QAbstractItemView {
        background: #111b2e;
        color: #f4f8ff;
        border: 1px solid #4a6287;
        selection-background-color: #2f62bb;
        selection-color: #ffffff;
        outline: 0px;
    }
    QPushButton {
        background-color: #2b5fba;
        border: 1px solid #4f7fd4;
        border-radius: 6px;
        color: #ffffff;
        min-height: 32px;
        font-weight: 700;
        padding: 4px 16px;
    }
    QPushButton:hover { background: #3d73ce; }
    QPushButton#btnOk {
        background-color: #13a15d;
        border: 1px solid #38c47f;
    }
    QPushButton#btnOk:hover { background: #19bc6d; }
    QPushButton#btnCancel {
        background-color: #4a1620;
        border: 1px solid #c04a63;
    }
    QPushButton#btnCancel:hover { background: #5d1e2b; }
    QPushButton#btnBrowsePath {
        background-color: #2b5fba;
        border: 1px solid #4f7fd4;
        min-height: 28px;
        min-width: 36px;
        padding: 0px;
    }
    QPushButton#btnBrowsePath:hover { background: #3d73ce; }
    QPushButton#btnBrowseClasses {
        background-color: #2b5fba;
        border: 1px solid #4f7fd4;
        min-height: 28px;
        min-width: 36px;
        padding: 0px;
    }
    QPushButton#btnBrowseClasses:hover { background: #3d73ce; }
    /* 保存选项复选框样式 */
    QCheckBox#chkSaveNG {
        color: #FF8A80;
        font-weight: bold;
        background-color: #3a0a10;
        border: 1px solid #c04a63;
        border-radius: 4px;
        padding: 4px 8px;
        spacing: 6px;
    }
    QCheckBox#chkSaveNG::indicator {
        width: 16px;
        height: 16px;
        border: 2px solid #c04a63;
        border-radius: 3px;
        background-color: #2a0508;
    }
    QCheckBox#chkSaveNG::indicator:checked {
        background-color: #d04a63;
        border-color: #ff8099;
    }
    QCheckBox#chkSaveOK {
        color: #B9F6CA;
        font-weight: bold;
        background-color: #0a2a10;
        border: 1px solid #38c47f;
        border-radius: 4px;
        padding: 4px 8px;
        spacing: 6px;
    }
    QCheckBox#chkSaveOK::indicator {
        width: 16px;
        height: 16px;
        border: 2px solid #38c47f;
        border-radius: 3px;
        background-color: #051a08;
    }
    QCheckBox#chkSaveOK::indicator:checked {
        background-color: #38c47f;
        border-color: #69f0ae;
    }
   </string>
