  <property name="styleSheet">
   <string notr="true">
    QDialog {
        background-color: #0a0d14;
        color: #eef4ff;
    }
    QGroupBox {
        color: #f2f6ff;
        border: 1px solid #364967;
        border-radius: 8px;
        margin-top: 14px;
        padding-top: 8px;
        font-weight: bold;
    }
    QGroupBox::title { left: 12px; padding: 0 6px; top: -2px; }
    QLabel {
        color: #eaf2ff;
    }
    QLineEdit, QDoubleSpinBox, QSpinBox, QComboBox {
        background-color: #111b2e;
        border: 1px solid #465e83;
        border-radius: 6px;
        color: #f4f8ff;
        selection-background-color: #2f62bb;
        selection-color: #ffffff;
        padding: 6px;
        min-height: 25px;
    }
    QLineEdit:focus, QSpinBox:focus, QDoubleSpinBox:focus {
        border: 1px solid #4f7fd4;
    }
    QComboBox QAbstractItemView {
        background: #111b2e;
        color: #f4f8ff;
        border: 1px solid #4a6287;
        selection-background-color: #2f62bb;
        selection-color: #ffffff;
        outline: 0px;
    }
    QPushButton {
        background-color: #2b5fba;
        border: 1px solid #4f7fd4;
        border-radius: 6px;
        color: #ffffff;
        min-height: 32px;
        font-weight: 700;
        padding: 4px 16px;
    }
    QPushButton:hover { background: #3d73ce; }
    QPushButton#btnOk {
        background-color: #13a15d;
        border: 1px solid #38c47f;
    }
    QPushButton#btnOk:hover { background: #19bc6d; }
    QPushButton#btnCancel {
        background-color: #4a1620;
        border: 1px solid #c04a63;
    }
    QPushButton#btnCancel:hover { background: #5d1e2b; }
    QPushButton#btnBrowsePath {
        background-color: #2b5fba;
        border: 1px solid #4f7fd4;
        min-height: 28px;
        min-width: 36px;
        padding: 0px;
    }
    QPushButton#btnBrowsePath:hover { background: #3d73ce; }
    QPushButton#btnBrowseClasses {
        background-color: #2b5fba;
        border: 1px solid #4f7fd4;
        min-height: 28px;
        min-width: 36px;
        padding: 0px;
    }
    QPushButton#btnBrowseClasses:hover { background: #3d73ce; }
   </string>
